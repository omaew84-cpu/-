# OpenWeatherMap API
NEXT_PUBLIC_OPENWEATHER_API_KEY=your_api_key_here
NEXT_PUBLIC_OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5

# Geolocation API (optional, for auto-detect)
NEXT_PUBLIC_GEOLOCATION_API=https://api.geojs.io/v1/geo

# App Settings
NEXT_PUBLIC_APP_NAME=Weather Dashboard
NEXT_PUBLIC_REFRESH_INTERVAL=600000
